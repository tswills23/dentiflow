# ============================================================
# DentiFlow Speed-to-Lead + Recall + Voice Agent
# Copy to .env and fill in real values
# ============================================================

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (Claude API for STL responses)
ANTHROPIC_API_KEY=

# Twilio (SMS for STL + Recall)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
SMS_LIVE_MODE=false

# Retell AI (Voice Agent)
RETELL_API_KEY=

# Cloudflare Worker (set in wrangler.toml or CF dashboard, not here)
# WORKER_BASE_URL=

# Server
PORT=3000

# Recall Cron (hourly sequence orchestrator)
RECALL_CRON_ENABLED=true

# Practice Config
DEFAULT_PRACTICE_ID=

# Dashboard (Vite env vars)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
