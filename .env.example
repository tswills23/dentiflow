# ============================================================
# DentiFlow Speed-to-Lead + Recall + Voice Agent
# Copy to .env and fill in real values
# ============================================================

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (Claude API for STL responses)
ANTHROPIC_API_KEY=

# Twilio (SMS for STL + Recall)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
SMS_LIVE_MODE=false

# Retell AI (Voice Agent)
RETELL_API_KEY=

# Cloudflare Worker (set in wrangler.toml or CF dashboard, not here)
# WORKER_BASE_URL=

# Server
PORT=3000

# Recall Cron (hourly sequence orchestrator)
RECALL_CRON_ENABLED=true

# Recall Reply LLM Path
# Default disabled. Per-practice DB flag (practices.recall_llm_enabled) is the
# primary kill switch — flip it via SQL UPDATE for instant rollback.
# RECALL_LLM_ENABLED gates the entire LLM path globally.
# RECALL_LLM_FORCE_OFF is the in-memory nuclear option (any truthy value disables).
# Hourly cap bounds worst-case spend + send count per practice.
RECALL_LLM_ENABLED=false
RECALL_LLM_FORCE_OFF=
RECALL_LLM_MIN_CONFIDENCE=0.7
RECALL_LLM_HOURLY_CAP=50

# Recall Reply Monitor (15-min cron — auto-disables LLM on validator blocks)
RECALL_REPLY_MONITOR_ENABLED=true

# Phone number to receive monitor alerts (E.164 format, e.g. +16306400029)
ALERT_PHONE_NUMBER=

# Practice Config
DEFAULT_PRACTICE_ID=

# Dashboard (Vite env vars)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
